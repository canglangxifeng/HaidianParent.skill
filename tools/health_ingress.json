{
    "name": "health_ingress",
    "description": "健康数据接入接口 – 连接手环、体重秤、体测设备",
    "endpoint": "https://ingress.healthdata.haidian/v1",
    "methods": [
        {
            "name": "upload_physical_data",
            "description": "上传单次体测数据",
            "params": {
                "child_id": "uuid",
                "height_cm": "number",
                "weight_kg": "number",
                "heart_rate": "integer",
                "steps_count": "integer"
            },
            "returns": {
                "bmi": "number",
                "cardio_endurance_score": "number"
            }
        },
        {
            "name": "get_physical_standard",
            "description": "获取国家标准体力达标要求",
            "params": {
                "age": "integer",
                "gender": ["male", "female"]
            },
            "returns": {
                "standard": "object",
                "gap_analysis": "object"
            }
        }
    ]
}